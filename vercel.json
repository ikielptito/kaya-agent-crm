{
  "functions": {
    "api/supabase.js": { "maxDuration": 60 },
    "api/whatsapp-webhook.js": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "^/(lib|dev)(/.*)?$", "status": 404 },
    { "src": "^/(SCHEMA\\.sql|PERSONA_SPEC\\.md|README\\.md)$", "status": 404 },
    { "handle": "filesystem" }
  ],
  "crons": [
    {
      "path": "/api/cron-followups?wave=0",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron-followups?wave=1",
      "schedule": "20 1 * * *"
    },
    {
      "path": "/api/cron-followups?wave=2",
      "schedule": "40 1 * * *"
    }
  ]
}
